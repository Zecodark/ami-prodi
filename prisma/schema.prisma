// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =========================================================
// 1. ROLES
// =========================================================
model Role {
  id         Int      @id @default(autoincrement())
  nama_role  String   @unique @db.VarChar(50)
  deskripsi  String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)

  users User[]

  @@map("roles")
}

// =========================================================
// 2. USERS
// =========================================================
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(50)
  password      String    @db.VarChar(255)
  role_id       Int?
  prodi_id      Int?
  is_active     Boolean   @default(true)
  last_login_at DateTime? @db.Timestamp(0)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  role  Role?  @relation(fields: [role_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  prodi Prodi? @relation(fields: [prodi_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  dosen Dosen?

  instrumens_created  Instrumen[]       @relation("InstrumenCreatedBy")
  isian_reviewed      IsianAmi[]        @relation("IsianReviewedBy")
  isian_bukti_uploads IsianBuktiFile[]  @relation("BuktiFIleUploadedBy")
  review_logs         IsianReviewLog[]  @relation("ReviewLogReviewer")
  password_reset_otps PasswordResetOtp[]
  login_otps          LoginOtp[]

  @@index([role_id])
  @@index([prodi_id])
  @@map("users")
}

// =========================================================
// 3. JURUSANS
// =========================================================
model Jurusan {
  id           Int      @id @default(autoincrement())
  nama_jurusan String   @unique @db.VarChar(30)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  prodis Prodi[]

  @@map("jurusans")
}

// =========================================================
// 4. PRODIS
// =========================================================
model Prodi {
  id         Int      @id @default(autoincrement())
  jurusan_id Int?
  nama_prodi String   @db.VarChar(50)
  jenjang    String?  @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)

  jurusan Jurusan? @relation(fields: [jurusan_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  dosens  Dosen[]
  isians   IsianAmi[]
  users    User[]
  instrumen_links InstrumenProdi[]

  @@unique([nama_prodi, jurusan_id])
  @@index([jurusan_id])
  @@map("prodis")
}

// =========================================================
// 5. DOSENS
// =========================================================
model Dosen {
  id                 Int      @id @default(autoincrement())
  user_id            Int?     @unique
  prodi_id           Int?
  nip                String   @unique @db.VarChar(20)
  nama_lengkap       String   @db.VarChar(50)
  status_kepegawaian String   @db.VarChar(50)
  no_hp              String?  @db.VarChar(20)
  alamat             String?  @db.Text
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now()) @db.Timestamp(0)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamp(0)

  user   User?  @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  prodi  Prodi? @relation(fields: [prodi_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  isians IsianAmi[]

  @@index([prodi_id])
  @@map("dosens")
}

// =========================================================
// 6. PERIODES
// =========================================================
model Periode {
  id              Int       @id @default(autoincrement())
  tahun           String    @unique @db.VarChar(10)
  is_active       Boolean   @default(false)
  tanggal_mulai   DateTime? @db.Date
  tanggal_selesai DateTime? @db.Date
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  instrumens Instrumen[]
  isians     IsianAmi[]

  @@index([is_active])
  @@map("periodes")
}

// =========================================================
// 7. INSTRUMENS
// =========================================================
model Instrumen {
  id             Int      @id @default(autoincrement())
  periode_id     Int?
  nama_instrumen String   @db.VarChar(50)
  deskripsi      String?  @db.Text
  is_active      Boolean  @default(true)
  created_by     Int?
  created_at     DateTime @default(now()) @db.Timestamp(0)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamp(0)

  periode          Periode?          @relation(fields: [periode_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  creator          User?             @relation("InstrumenCreatedBy", fields: [created_by], references: [id], onDelete: SetNull, onUpdate: Cascade)
  kriteria_standars KriteriaStandar[]
  prodi_links       InstrumenProdi[]

  @@index([periode_id])
  @@index([is_active])
  @@index([created_by])
  @@map("instrumens")
}

// =========================================================
// 7.5. INSTRUMEN PRODIS
// =========================================================
model InstrumenProdi {
  id           Int       @id @default(autoincrement())
  instrumen_id Int
  prodi_id     Int
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  instrumen    Instrumen @relation(fields: [instrumen_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  prodi        Prodi     @relation(fields: [prodi_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([instrumen_id, prodi_id])
  @@index([instrumen_id])
  @@index([prodi_id])
  @@map("instrumen_prodis")
}

// =========================================================

// 8. KRITERIA STANDAR
// =========================================================
model KriteriaStandar {
  id            Int      @id @default(autoincrement())
  instrumen_id  Int
  kode_kriteria String   @db.VarChar(50)
  nama_kriteria String   @db.VarChar(50)
  deskripsi     String?  @db.Text
  urutan        Int      @default(1) @db.UnsignedInt
  created_at    DateTime @default(now()) @db.Timestamp(0)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(0)

  instrumen  Instrumen  @relation(fields: [instrumen_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  kode_amis  KodeAmi[]

  @@unique([instrumen_id, kode_kriteria])
  @@index([instrumen_id])
  @@index([urutan])
  @@map("kriteria_standars")
}

// =========================================================
// 9. KODE AMI
// =========================================================
model KodeAmi {
  id          Int      @id @default(autoincrement())
  kriteria_id Int
  kode_ami    String   @db.VarChar(50)
  urutan      Int      @default(1) @db.UnsignedInt
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamp(0)

  kriteria         KriteriaStandar        @relation(fields: [kriteria_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  butir_standars   KodeAmiButirStandar[]
  deskripsi_areas  DeskripsiArea[]

  @@unique([kriteria_id, kode_ami])
  @@index([kriteria_id])
  @@index([urutan])
  @@map("kode_amis")
}

// =========================================================
// 10. JENJANG STANDAR
// =========================================================
model JenjangStandar {
  id           Int      @id @default(autoincrement())
  kode_jenjang String   @unique @db.VarChar(10)
  nama_jenjang String   @db.VarChar(50)
  urutan       Int      @default(1) @db.UnsignedInt
  created_at   DateTime @default(now()) @db.Timestamp(0)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  butir_standars KodeAmiButirStandar[]

  @@map("jenjang_standars")
}

// =========================================================
// 11. KODE AMI BUTIR STANDAR
// =========================================================
model KodeAmiButirStandar {
  id          Int      @id @default(autoincrement())
  kode_ami_id Int
  jenjang_id  Int
  no_butir    String?  @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamp(0)

  kode_ami KodeAmi        @relation(fields: [kode_ami_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  jenjang  JenjangStandar @relation(fields: [jenjang_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([kode_ami_id, jenjang_id])
  @@index([kode_ami_id])
  @@index([jenjang_id])
  @@map("kode_ami_butir_standars")
}

// =========================================================
// 12. DESKRIPSI AREA
// =========================================================
model DeskripsiArea {
  id                  Int      @id @default(autoincrement())
  kode_ami_id         Int
  deskripsi_area_audit String  @db.Text
  target_standar      String?  @db.Text
  urutan              Int      @default(1) @db.UnsignedInt
  created_at          DateTime @default(now()) @db.Timestamp(0)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamp(0)

  kode_ami            KodeAmi            @relation(fields: [kode_ami_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pemeriksaan_unsurs  PemeriksaanUnsur[]

  @@index([kode_ami_id])
  @@index([urutan])
  @@map("deskripsi_areas")
}

// =========================================================
// 13. PEMERIKSAAN UNSUR
// =========================================================
model PemeriksaanUnsur {
  id                Int      @id @default(autoincrement())
  deskripsi_area_id Int
  isi_unsur         String   @db.Text
  urutan            Int      @default(1) @db.UnsignedInt
  created_at        DateTime @default(now()) @db.Timestamp(0)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamp(0)

  deskripsi_area DeskripsiArea @relation(fields: [deskripsi_area_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  isians         IsianAmi[]

  @@index([deskripsi_area_id])
  @@index([urutan])
  @@map("pemeriksaan_unsurs")
}

// =========================================================
// 14. ISIAN AMI
// =========================================================
enum KetersediaanStandar {
  ada
  tidak_ada
}

enum DokumenStatus {
  ada
  tidak_ada
}

enum IsianStatus {
  draft
  proses
  valid
  revisi
  superseded
}

model IsianAmi {
  id                          Int                 @id @default(autoincrement())
  pemeriksaan_unsur_id        Int
  periode_id                  Int
  dosen_id                    Int
  prodi_id                    Int?

  judul_dokumen               String?             @db.VarChar(100)
  ketersediaan_standar        KetersediaanStandar @default(tidak_ada)
  dokumen                     DokumenStatus       @default(tidak_ada)

  pencapaian_standar_spt_pt   Boolean             @default(false)
  pencapaian_standar_sn_dikti Boolean             @default(false)

  daya_saing_lokal            Boolean             @default(false)
  daya_saing_nasional         Boolean             @default(false)
  daya_saing_internasional    Boolean             @default(false)

  bukti_link                  String?             @db.VarChar(255)
  tahun_pelaksanaan           String?             @db.Char(4)
  capaian                     String?             @db.Text
  keterangan                  String?             @db.Text

  status                      IsianStatus         @default(proses)
  catatan_kaprodi             String?             @db.Text

  reviewed_by                 Int?
  reviewed_at                 DateTime?           @db.Timestamp(0)

  attempt                     Int                 @default(1) @db.UnsignedInt

  submitted_at                DateTime?           @db.Timestamp(0)
  created_at                  DateTime            @default(now()) @db.Timestamp(0)
  updated_at                  DateTime            @default(now()) @updatedAt @db.Timestamp(0)

  pemeriksaan_unsur PemeriksaanUnsur @relation(fields: [pemeriksaan_unsur_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  periode           Periode          @relation(fields: [periode_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  dosen             Dosen            @relation(fields: [dosen_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  prodi             Prodi?           @relation(fields: [prodi_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reviewer          User?            @relation("IsianReviewedBy", fields: [reviewed_by], references: [id], onDelete: SetNull, onUpdate: Cascade)

  bukti_files  IsianBuktiFile[]
  review_logs  IsianReviewLog[]

  @@unique([pemeriksaan_unsur_id, periode_id, dosen_id])
  @@index([pemeriksaan_unsur_id])
  @@index([periode_id])
  @@index([dosen_id])
  @@index([prodi_id])
  @@index([status])
  @@index([reviewed_by])
  @@index([submitted_at])
  @@map("isian_ami")
}

// =========================================================
// 15. ISIAN BUKTI FILES
// =========================================================
model IsianBuktiFile {
  id                 Int      @id @default(autoincrement())
  isian_id           Int
  original_name      String   @db.VarChar(255)
  file_name          String   @db.VarChar(255)
  file_path          String   @db.VarChar(500)
  mime_type          String?  @db.VarChar(100)
  file_size          Int?

  judul_dokumen      String?  @db.VarChar(255)
  keterangan_dokumen String?  @db.Text
  tahun_dokumen      String?  @db.VarChar(10)

  uploaded_by        Int?
  created_at    DateTime @default(now()) @db.Timestamp(0)

  isian       IsianAmi @relation(fields: [isian_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploader    User?    @relation("BuktiFIleUploadedBy", fields: [uploaded_by], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([isian_id])
  @@index([uploaded_by])
  @@map("isian_bukti_files")
}

// =========================================================
// 16. ISIAN REVIEW LOGS
// =========================================================
model IsianReviewLog {
  id              Int         @id @default(autoincrement())
  isian_id        Int
  reviewer_id     Int?

  status_sebelum  IsianStatus?
  status_sesudah  IsianStatus

  catatan         String?  @db.Text
  created_at      DateTime @default(now()) @db.Timestamp(0)

  isian    IsianAmi @relation(fields: [isian_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer User?    @relation("ReviewLogReviewer", fields: [reviewer_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([isian_id])
  @@index([reviewer_id])
  @@index([status_sesudah])
  @@map("isian_review_logs")
}

// =========================================================
// 17. PASSWORD RESET OTPS
// =========================================================
model PasswordResetOtp {
  id            Int       @id @default(autoincrement())
  user_id       Int
  email         String    @db.VarChar(50)
  otp_hash      String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  used_at       DateTime? @db.Timestamp(0)
  attempt_count Int       @default(0) @db.UnsignedInt
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id])
  @@index([email])
  @@map("password_reset_otps")
}

// =========================================================
// 18. LOGIN OTPS (MFA)
// =========================================================
model LoginOtp {
  id            Int       @id @default(autoincrement())
  user_id       Int
  email         String    @db.VarChar(50)
  otp_hash      String    @db.VarChar(255)
  expires_at    DateTime  @db.Timestamp(0)
  used_at       DateTime? @db.Timestamp(0)
  attempt_count Int       @default(0) @db.UnsignedInt
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id])
  @@index([email])
  @@map("login_otps")
}
